# Copy this file to `.env.local` and fill in values. Never commit `.env.local`.

# Where contact form submissions are delivered (your inbox)
CONTACT_TO_EMAIL=njayasalazar@gmail.com

# SMTP — Gmail example (use an App Password, not your normal login)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-16-char-app-password

# Use port 587 with STARTTLS if your provider requires it:
# SMTP_PORT=587
# SMTP_SECURE=false
#
# Other providers: set SMTP_HOST / SMTP_PORT to match their docs (e.g. SendGrid, Mailgun SMTP).
